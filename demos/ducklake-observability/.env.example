# DuckLake Observability — environment variables
# Copy to .env and edit as needed

# Target DuckLake PostgreSQL catalog connection
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=lake_catalog
PG_USER=postgres
PG_PASSWORD=postgres

# Convenience URL for psql
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lake_catalog

# Grafana port
GRAFANA_PORT=3100

# Storage quota for the growth alert (GB)
STORAGE_QUOTA_GB=100
